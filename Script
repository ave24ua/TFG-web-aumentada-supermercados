      current.hideGluten = hideGlutenCheckbox.checked;
      Utils.setFilterOptions(current);
      Filters.reapplyAll();
    });

    hideGlutenRow.appendChild(hideGlutenLeft);
    hideGlutenRow.appendChild(hideGlutenCheckbox);
    menu.appendChild(hideGlutenRow);

